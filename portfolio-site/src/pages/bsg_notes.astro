---
import Header from "../components/Header.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
import "../styles/links.css";
---
<html class="BSG-Notes" lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content={`Resources and downloadable notes for the Bharat Scouts and Guides — curriculum, flags, history, uniform, pioneering and more. Curated by ${siteConfig.name}.`} />
    <meta property="og:description" content={`Resources and downloadable notes for the Bharat Scouts and Guides — curriculum, flags, history, uniform, pioneering and more. Curated by ${siteConfig.name}.`} />
    <title>BSG Notes - {siteConfig.name}</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;1,100;1,200;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header />
  <main id="hero" class="relative isolate overflow-hidden bg-gray-50 py-24 md:h-screen" style={`--accent-color: ${siteConfig.accentColor}`}>
  <!-- Optional background image (drop public/images/links-bg.jpg to use) -->
  <div class="absolute inset-0 -z-20 links-bg" aria-hidden="true" />
  <div class="absolute inset-0 -z-10 hero-overlay" aria-hidden="true"></div>
      <svg
        aria-hidden="true"
        class="hero-bg-svg absolute inset-0 -z-10 size-full stroke-gray-200 [mask-image:radial-gradient(100%_100%_at_top_right,white,transparent)]"
      >
        <defs>
          <pattern
            x="50%"
            y={-1}
            id="links-coming-soon-pattern"
            width={200}
            height={200}
            patternUnits="userSpaceOnUse"
          >
            <path d="M.5 200V.5H200" fill="none"></path>
          </pattern>
          <pattern
            id="links-programming-symbols"
            x="0"
            y="0"
            width="400"
            height="400"
            patternUnits="userSpaceOnUse"
          >
            <text x="50" y="50" fill={siteConfig.accentColor} font-family="monospace" font-size="24" transform="rotate(-15)">&lt;/&gt;</text>
          </pattern>
        </defs>
        <rect fill="url(#links-programming-symbols)" width="100%" height="100%" opacity="0.12"></rect>
        <rect fill="url(#links-coming-soon-pattern)" width="100%" height="100%" stroke-width={0}></rect>
      </svg>
      <div class="h-full mx-auto p-8 sm:p-12 md:p-24 flex items-center">
        <div class="card max-w-3xl mx-auto bg-white dark:bg-gray-900/60 backdrop-blur-sm rounded-xl p-8 md:p-12 text-center border border-gray-100 dark:border-gray-800">
          <img class="avatar avatar--rounded" src="/images/75-bsg.png" srcset="/images/75-bsg.png 2x" alt="The Bharat Scouts and Guides" />
          <h1>Bharat Scouts and Guides</h1>
          <p class="lead">“The Bharat Scouts and Guides is a voluntary, non-political, educational Movement for young people, open to all without distinction of origin, race or creed, in accordance with the purpose, principles and methods conceived by the founder Lord Baden-Powell in 1907.”</p>

          <nav class="button-stack" role="navigation">
            <a class="button button-default" href="https://drive.google.com/file/d/1oAU4HUCcqafWF8Heg_p2zsIeYSlNpLpL/view?usp=drive_link" target="_blank" rel="noopener"><img class="icon site-icon-dark-fix" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive Icon" />Advancement of Scouting in India</a>
            <a class="button button-default" href="https://drive.google.com/file/d/1nBSZpf-MVB67Gaa5XqqOMZ3cJjz5-YW7/" target="_blank" rel="noopener"><img class="icon site-icon-dark-fix" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive Icon" />Flags</a>
            <a class="button button-default" href="https://drive.google.com/file/d/1cD2hpRtk16KJXHuHA4414B_K_qgHAeqR/view?usp=drive_link" target="_blank" rel="noopener"><img class="icon site-icon-dark-fix" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive Icon" />History of Scouting in India</a>
            <a class="button button-default" href="https://drive.google.com/file/d/15Jcer6ZhEUOKESsCppqGBthztZCj8xAv/view?usp=drive_link" target="_blank" rel="noopener"><img class="icon site-icon-dark-fix" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive Icon" />Promise and Law</a>
            <a class="button button-default" href="https://drive.google.com/file/d/1NGLOIff1zdmL2NZDgeCfCLryFBomilCw/view?usp=drive_link" target="_blank" rel="noopener"><img class="icon site-icon-dark-fix" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive Icon" />Scout Motto || Sign || Salute || Left Handshake</a>
            <a class="button button-default" href="https://drive.google.com/file/d/1j0M4s49-lMQOeGM9VsnvixFZ-HMaVUCh/view?usp=drive_link" target="_blank" rel="noopener"><img class="icon site-icon-dark-fix" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive Icon" />Uniform</a>
            <a class="button button-default" href="https://drive.google.com/file/d/10xaaPqdP3ykimqeOZQyW1h33ax9w4SMJ/view?usp=drive_link" target="_blank" rel="noopener"><img class="icon site-icon-dark-fix" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive Icon" />Fire Triangle</a>
            <a class="button button-default" href="https://docs.google.com/presentation/d/1uCfSx_6XCYcln4TO4FrNopSJhZoeoEbX/edit?usp=drive_link&ouid=108453966729985619454&rtpof=true&sd=true " target="_blank" rel="noopener"><img class="icon site-icon-dark-fix" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive Icon" />Pioneering - Part 1</a>
          </nav>

          <footer>
            <p>Copyright © {new Date().getFullYear()} Shraman Chaudhuri</p>
            <p>Copyright © {new Date().getFullYear()} Bharat Scouts and Guides</p>
          </footer>
        </div>
      </div>
    </main>

    <ThemeToggle />
  </body>
</html>
