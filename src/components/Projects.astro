---
// @ts-nocheck
import { siteConfig } from "../config";
const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

{
  hasProjects && (
    <section id="projects" class="py-24 px-8 sm:px-12 md:px-24 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-[1200px] flex flex-col items-center">
        <!-- Section Title Block -->
        <div class="flex flex-col items-center mb-16">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Selected Works
          </span>
          <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
            WORK
          </h2>
        </div>

        <!-- Bento Grid of Projects -->
        <div class="bento-grid w-full text-left">
          {siteConfig.projects.map((project, index) => {
            const Component = project.link ? "a" : "div";
            const linkProps = project.link
              ? {
                  href: project.link,
                  target: "_blank",
                  rel: "noopener noreferrer",
                }
              : {};

            return (
              <div class="group relative">
                <Component
                  {...linkProps}
                  class={`block relative overflow-hidden p-8 sm:p-10 bg-paper-white rounded-cards border border-silver/50 transition-all duration-300 shadow-subtle ${
                    project.link ? "hover:-translate-y-1 hover:border-silver" : ""
                  }`}
                >
                  {project.link && (
                    <div class="absolute top-8 right-8 w-10 h-10 flex items-center justify-center bg-obsidian text-paper-white rounded-full transition-all duration-200 group-hover:bg-solar-beam group-hover:text-obsidian">
                      <svg
                        class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M7 17L17 7M17 7H7M17 7V17"
                        />
                      </svg>
                    </div>
                  )}

                  <div class="flex flex-col gap-6">
                    <div class="flex items-center gap-3">
                      <span class="font-inter font-medium text-caption text-ash">
                        0{index + 1}
                      </span>
                      <h3 class="font-inter font-medium text-subheading text-obsidian">
                        {project.name}
                      </h3>
                    </div>

                    <p class={`font-inter-display font-medium text-body text-graphite leading-relaxed ${project.link ? "pr-12" : ""}`}>
                      {project.description}
                    </p>

                    {project.skills && project.skills.length > 0 && (
                      <div class="flex flex-wrap gap-2 pt-2">
                        {project.skills.map((skill) => (
                          <span
                            class="px-3 py-1 bg-concrete text-graphite rounded-buttons text-caption font-inter font-medium border border-silver/50 transition-colors duration-200 group-hover:bg-solar-beam group-hover:text-obsidian group-hover:border-solar-beam"
                          >
                            {skill}
                          </span>
                        ))}
                      </div>
                    )}
                  </div>
                </Component>
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )
}
