---
import { siteConfig } from "../config";

const hasProjects = siteConfig.projects && siteConfig.projects.length > 0;
---

<header
  id="header"
  class="fixed top-0 left-0 right-0 z-50 flex justify-center pt-6"
>
  <nav class="flex items-center gap-6 pl-6 pr-2 py-2 bg-[#1f1f1f] text-white rounded-navcapsule font-inter text-body-sm transition-all duration-300 ease-in-out shadow-none border border-white/10">
    <!-- Icon Glyph -->
    <div class="flex items-center justify-center">
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-3 h-3">
        <circle cx="6" cy="6" r="5" stroke="white" stroke-width="1"/>
      </svg>
    </div>
    
    <!-- Nav Links -->
    <ul class="flex items-center gap-6">
      { hasProjects && <li><a href="/#projects" class="hover:text-solar-beam transition-colors font-medium">Work</a></li> }
      <li><a href="/#about" class="hover:text-solar-beam transition-colors font-medium">Story</a></li>
      <li><a href="/#classroom-notes" class="hover:text-solar-beam transition-colors font-medium">Process</a></li>
      <li><a href="/connect" class="hover:text-solar-beam transition-colors font-medium">Connect</a></li>
    </ul>

    <!-- Highlight Button -->
    <a 
      href="/#projects" 
      class="px-5 py-2 bg-solar-beam text-black rounded-buttons font-inter text-body-sm font-medium hover:bg-white hover:text-black transition-colors duration-200"
    >
      View Work
    </a>
  </nav>
</header>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
