---
// @ts-nocheck
import { siteConfig } from "../config";
---

{
  siteConfig.classroomNotes && siteConfig.classroomNotes.length > 0 && (
    <section id="classroom-notes" class="py-24 px-8 sm:px-12 md:px-24 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-[1200px] flex flex-col items-center">
        <!-- Section Title Block -->
        <div class="flex flex-col items-center mb-16">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Classroom Notes
          </span>
          <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
            PROCESS
          </h2>
        </div>

        <!-- Vertical Stack of Notes -->
        <div class="flex flex-col items-center gap-8 w-full">
          {siteConfig.classroomNotes.map((note, index) => (
            <div class="w-full max-w-3xl group relative text-left">
              <a
                href={note.link}
                target="_blank"
                rel="noopener noreferrer"
                class="block relative overflow-hidden p-8 sm:p-10 bg-paper-white rounded-cards border border-silver/50 shadow-subtle transition-all duration-300 hover:border-silver"
              >
                <div class="absolute top-8 right-8 w-10 h-10 flex items-center justify-center bg-obsidian text-paper-white rounded-full transition-all duration-200 group-hover:bg-solar-beam group-hover:text-obsidian">
                  <svg
                    class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M7 17L17 7M17 7H7M17 7V17"
                    />
                  </svg>
                </div>

                <div class="flex flex-col gap-4 pr-12">
                  <div>
                    <span class="font-inter font-medium text-caption text-ash">
                      0{index + 1}
                    </span>
                    <h3 class="font-inter font-medium text-subheading text-obsidian mt-1">
                      {note.name}
                    </h3>
                  </div>
                  <p class="font-inter-display font-medium text-body text-graphite leading-relaxed">
                    {note.description}
                  </p>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
