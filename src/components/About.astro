---
import { siteConfig } from "../config";
---

<section id="about" class="py-24 px-8 sm:px-12 md:px-24 bg-concrete flex flex-col items-center text-center">
  <div class="w-full max-w-[1200px] flex flex-col items-center">
    <!-- Section Title Block -->
    <div class="flex flex-col items-center mb-16">
      <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
        From 2020 til today
      </span>
      <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
        STORY
      </h2>
    </div>

    <!-- Content Block -->
    <div class="max-w-3xl flex flex-col items-center gap-10">
      <p class="font-inter-display font-medium text-subheading leading-relaxed text-graphite text-center">
        {siteConfig.aboutMe}
      </p>

      <!-- Skills Chips -->
      <div class="pt-6">
        <div class="flex flex-wrap justify-center gap-3">
          {
            siteConfig.skills.map((skill) => (
              <span class="inline-flex items-center px-4 py-2 bg-paper-white text-graphite rounded-buttons text-body-sm font-inter-display font-medium border border-silver select-none transition-all duration-200 hover:bg-solar-beam hover:text-obsidian hover:border-solar-beam">
                {skill}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
