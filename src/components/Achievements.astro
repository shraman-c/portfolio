---
// @ts-nocheck
import { siteConfig } from "../config";
import { GlowingEffect } from "@/components/ui/glowing-effect";
const hasAchievements = siteConfig.achievements && siteConfig.achievements.length > 0;
---

{
  hasAchievements && (
    <section id="achievements" class="p-8 sm:p-12 md:p-16 lg:p-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16 items-start">
        <div class="lg:col-span-4">
          <h2 class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl font-bold text-gray-900">Achievements</h2>
          <div class="w-[75px] h-[5px] mt-2 rounded-full" style={`background-color: ${siteConfig.accentColor}`} />
        </div>

        <div class="lg:col-span-8">
          <div class="bento-grid">
            {siteConfig.achievements.map((a, i) => (
              <div class="group relative">
                <div class={`block relative overflow-visible p-4 sm:p-6 md:p-8 bg-gray-50 rounded-xl sm:rounded-2xl border border-gray-200 transition-all duration-300 aceternity-glow`} style={`--accent-color: ${siteConfig.accentColor}`}>
                  <GlowingEffect client:idle glow={true} disabled={false} />
                  <div class="space-y-3">
                    <div class="flex items-baseline justify-between">
                      <span class="text-sm font-mono" style={{ color: siteConfig.accentColor }}>{`0${i + 1}`}</span>
                      {a.date && <span class="text-xs text-gray-500">{a.date}</span>}
                    </div>
                    <h3 class="text-xl sm:text-2xl font-bold text-gray-900">{a.title}</h3>
                    {a.description && <p class="text-gray-600">{a.description}</p>}
                    {a.link && (
                      <a class="text-sm text-blue-600 underline" href={a.link} target="_blank" rel="noopener noreferrer">Learn more</a>
                    )}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )
}
