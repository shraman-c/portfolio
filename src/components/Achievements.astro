---
// @ts-nocheck
import { siteConfig } from "../config";
const hasAchievements = siteConfig.achievements && siteConfig.achievements.length > 0;
---

{
  hasAchievements && (
    <section id="achievements" class="py-24 px-8 sm:px-12 md:px-24 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-[1200px] flex flex-col items-center">
        <!-- Section Title Block -->
        <div class="flex flex-col items-center mb-16">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Milestones & Awards
          </span>
          <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
            ACHIEVEMENTS
          </h2>
        </div>

        <!-- Bento Grid of Achievements -->
        <div class="bento-grid w-full text-left">
          {siteConfig.achievements.map((a, i) => (
            <div class="group relative">
              <div class="block relative overflow-hidden p-8 sm:p-10 bg-paper-white rounded-cards border border-silver/50 transition-all duration-300 shadow-subtle hover:border-silver">
                <div class="flex flex-col gap-6">
                  <div class="flex items-baseline justify-between w-full">
                    <span class="font-inter font-medium text-caption text-ash">{`0${i + 1}`}</span>
                    {a.date && <span class="font-inter font-medium text-caption text-ash">{a.date}</span>}
                  </div>
                  
                  <div class="space-y-2">
                    <h3 class="font-inter font-medium text-subheading text-obsidian">{a.title}</h3>
                    {a.description && (
                      <p class="font-inter-display font-medium text-body text-graphite leading-relaxed">
                        {a.description}
                      </p>
                    )}
                  </div>

                  {a.link && (
                    <div class="pt-2">
                      <a 
                        class="inline-flex items-center gap-1.5 px-4 py-2 bg-concrete text-obsidian rounded-buttons text-caption font-inter font-medium border border-silver/50 hover:bg-solar-beam hover:border-solar-beam transition-colors duration-200" 
                        href={a.link} 
                        target="_blank" 
                        rel="noopener noreferrer"
                      >
                        <span>Learn more</span>
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                        </svg>
                      </a>
                    </div>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
