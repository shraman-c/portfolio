---
// @ts-nocheck
import { siteConfig } from "../config";
---

<div
  id="hero"
  class="relative isolate overflow-hidden bg-concrete min-h-screen flex items-center"
>
  <!-- Solar Beam Gradient cutting from upper-right to lower-left -->
  <div
    class="absolute top-0 right-0 w-[80%] h-full -z-10 pointer-events-none"
    style="background: radial-gradient(circle at 100% 0%, var(--color-solar-beam) 0%, transparent 60%); opacity: 0.35; filter: blur(40px);"
  ></div>
  <div
    class="absolute top-0 right-0 w-full h-full -z-20 pointer-events-none"
    style="background: linear-gradient(225deg, rgba(255, 213, 0, 0.15) 0%, transparent 50%);"
  ></div>

  <div class="w-full max-w-none mx-auto p-8 sm:p-12 md:p-24 relative z-10 pt-32 pb-24 md:py-32">
    <div class="flex flex-col items-start gap-4">
      <!-- Lead Paragraph -->
      <p 
        class="text-graphite font-inter-display text-body font-medium leading-relaxed max-w-2xl animate-fade-in"
      >
        {siteConfig.title}
      </p>
      
      <!-- Display Name -->
      <h1
        class="text-obsidian font-reddit-sans-condensed font-black leading-none uppercase tracking-tighter animate-fade-in animation-delay-200 select-none cursor-default"
        style="font-size: clamp(64px, 14vw, 246px); letter-spacing: -0.028em; line-height: 0.95;"
      >
        {siteConfig.name}
      </h1>
    </div>
  </div>

  <!-- Social Icons at bottom left, styled flat -->
  <div
    class="hero-action-row absolute bottom-0 left-0 p-8 sm:p-12 md:p-24 flex gap-x-6 text-graphite animate-fade-in animation-delay-600 z-10"
  >
    {
      siteConfig.social?.email && (
        <a
          href={`mailto:${siteConfig.social.email}`}
          aria-label="Email"
          class="transition-colors duration-200 hover:text-obsidian"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
            <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z" /><path d="M3 7l9 6l9 -6" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.linkedin && (
        <a
          href={siteConfig.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="transition-colors duration-200 hover:text-obsidian"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
            <path d="M8 11v5" /><path d="M8 8v.01" /><path d="M12 16v-5" /><path d="M16 16v-3a2 2 0 1 0 -4 0" /><path d="M3 7a4 4 0 0 1 4 -4h10a4 4 0 0 1 4 4v10a4 4 0 0 1 -4 4h-10a4 4 0 0 1 -4 -4z" />
          </svg>
        </a>
      )
    }
    {
      siteConfig.social?.github && (
        <a
          href={siteConfig.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="transition-colors duration-200 hover:text-obsidian"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-6 w-6">
            <path d="M9 19c-4.3 1.4 -4.3 -2.5 -6 -3m12 5v-3.5c0 -1 .1 -1.4 -.5 -2c2.8 -.3 5.5 -1.4 5.5 -6a4.6 4.6 0 0 0 -1.3 -3.2a4.2 4.2 0 0 0 -.1 -3.2s-1.1 -.3 -3.5 1.3a12.3 12.3 0 0 0 -6.2 0c-2.4 -1.6 -3.5 -1.3 -3.5 -1.3a4.2 4.2 0 0 0 -.1 3.2a4.6 4.6 0 0 0 -1.3 3.2c0 4.6 2.7 5.7 5.5 6c-.6 .6 -.6 1.2 -.5 2v3.5" />
          </svg>
        </a>
      )
    }
  </div>
</div>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    opacity: 0;
  }
  .animation-delay-200 { animation-delay: 0.15s; }
  .animation-delay-600 { animation-delay: 0.4s; }
</style>
