---
import { siteConfig } from "../config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
    <title>Coming Soon - {siteConfig.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Inter:wght@500&family=Reddit+Sans+Condensed:wght@900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-concrete">
    <Header />

    <main class="min-h-screen py-32 flex items-center justify-center">
      <div class="w-full px-6">
        <div class="max-w-2xl mx-auto bg-paper-white rounded-cards border border-silver/50 p-8 sm:p-12 text-center shadow-subtle">
          <h1 class="font-reddit-sans-condensed font-black text-display text-obsidian tracking-tighter uppercase select-none mb-4">
            Coming Soon!
          </h1>
          <p class="font-inter-display font-medium text-body text-graphite mb-8 leading-relaxed">
            I'm working on something awesome. Stay tuned!
          </p>

          <p class="font-system-sans text-caption text-ash mt-8">© {new Date().getFullYear()} {siteConfig.name}</p>
        </div>
      </div>
    </main>

    <Footer />
    <ThemeToggle />
  </body>
</html>
