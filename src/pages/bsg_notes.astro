---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
import "../styles/links.css";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`Resources and downloadable notes for the Bharat Scouts and Guides — curriculum, flags, history, uniform, pioneering and more. Curated by ${siteConfig.name}.`} />
    <meta property="og:description" content={`Resources and downloadable notes for the Bharat Scouts and Guides — curriculum, flags, history, uniform, pioneering and more. Curated by ${siteConfig.name}.`} />
    <title>BSG Notes - {siteConfig.name}</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Inter:wght@500&family=Reddit+Sans+Condensed:wght@900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-concrete">
    <Header />
    <main class="min-h-screen py-32 flex items-center justify-center">
      <div class="w-full px-6">
        <div class="card">
          <img class="avatar avatar--rounded" src="/images/75-bsg.png" alt="The Bharat Scouts and Guides" />
          <h1>Bharat Scouts and Guides</h1>
          <p class="lead">“The Bharat Scouts and Guides is a voluntary, non-political, educational Movement for young people, open to all without distinction of origin, race or creed, in accordance with the purpose, principles and methods conceived by the founder Lord Baden-Powell in 1907.”</p>

          <nav class="button-stack" role="navigation">
            <a class="button button-default" href="https://drive.google.com/file/d/1oAU4HUCcqafWF8Heg_p2zsIeYSlNpLpL/view?usp=drive_link" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive" />
              <span>Advancement of Scouting</span>
            </a>
            <a class="button button-default" href="https://drive.google.com/file/d/1nBSZpf-MVB67Gaa5XqqOMZ3cJjz5-YW7/" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive" />
              <span>Flags</span>
            </a>
            <a class="button button-default" href="https://drive.google.com/file/d/1cD2hpRtk16KJXHuHA4414B_K_qgHAeqR/view?usp=drive_link" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive" />
              <span>History of Scouting</span>
            </a>
            <a class="button button-default" href="https://drive.google.com/file/d/15Jcer6ZhEUOKESsCppqGBthztZCj8xAv/view?usp=drive_link" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive" />
              <span>Promise and Law</span>
            </a>
            <a class="button button-default" href="https://drive.google.com/file/d/1NGLOIff1zdmL2NZDgeCfCLryFBomilCw/view?usp=drive_link" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive" />
              <span>Scout Motto / Sign</span>
            </a>
            <a class="button button-default" href="https://drive.google.com/file/d/1j0M4s49-lMQOeGM9VsnvixFZ-HMaVUCh/view?usp=drive_link" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive" />
              <span>Uniform Details</span>
            </a>
            <a class="button button-default" href="https://drive.google.com/file/d/10xaaPqdP3ykimqeOZQyW1h33ax9w4SMJ/view?usp=drive_link" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive" />
              <span>Fire Triangle</span>
            </a>
            <a class="button button-default" href="https://docs.google.com/presentation/d/1uCfSx_6XCYcln4TO4FrNopSJhZoeoEbX/edit?usp=drive_link&ouid=108453966729985619454&rtpof=true&sd=true " target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/drive.svg" alt="Drive" />
              <span>Pioneering - Part 1</span>
            </a>
          </nav>

          <footer>
            <p>Copyright © {new Date().getFullYear()} Shraman Chaudhuri</p>
            <p>Copyright © {new Date().getFullYear()} Bharat Scouts and Guides</p>
          </footer>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
