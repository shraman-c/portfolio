---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
import "../styles/links.css";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Links - {siteConfig.name}</title>
    <link rel="icon" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Inter:wght@500&family=Reddit+Sans+Condensed:wght@900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-concrete">
    <Header />
    <main class="min-h-screen py-32 flex items-center justify-center">
      <div class="w-full px-6">
        <div class="card">
          <img class="avatar avatar--rounded" src="/images/avt.png" alt="Shraman Chaudhuri" />
          <h1>Shraman Chaudhuri</h1>
          <p class="lead">Computer Science Engineering Student at Adamas University | Lifelong Learner | Exploring Code, Logic &amp; Innovation.</p>

          <nav class="button-stack" role="navigation">
            <a class="button button-default" href="https://shramanc.pages.dev" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/favicon.svg" alt="Homepage" />
              <span>Visit Portfolio</span>
            </a>
            <a class="button" href="https://github.com/shraman-c" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/github.svg" alt="GitHub" />
              <span>GitHub</span>
            </a>
            <a class="button" href="https://www.instagram.com/shraman_sc/" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/instagram.svg" alt="Instagram" />
              <span>Instagram</span>
            </a>
            <a class="button" href="https://www.linkedin.com/in/shramanchaudhuri" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/linkedin.svg" alt="LinkedIn" />
              <span>LinkedIn</span>
            </a>
            <a class="button" href="https://www.youtube.com/shramanchaudhuri" target="_blank" rel="noopener">
              <img class="icon" aria-hidden="true" src="/images/icons/youtube-alt.svg" alt="YouTube" />
              <span>YouTube</span>
            </a>
          </nav>

          <footer>
            <p>Copyright © {new Date().getFullYear()} Shraman Chaudhuri</p>
          </footer>
        </div>
      </div>
    </main>
    <Footer />
    <ThemeToggle />
  </body>
</html>
