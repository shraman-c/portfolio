---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
    <meta
      name="description"
      content="Simple Caesar Cipher tool to encrypt and decrypt text using a shift value."
    />
    <title>Caesar Cipher - {siteConfig.name}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Inter:wght@500&family=Reddit+Sans+Condensed:wght@900&display=swap"
      rel="stylesheet"
    />
  </head>

  <body class="bg-concrete text-obsidian">
    <Header />

    <main class="min-h-screen py-32 flex items-center justify-center">
      <section class="w-full max-w-4xl px-6 lg:px-8">
        <!-- Section Title Block -->
        <div class="text-center mb-12 flex flex-col items-center">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Text Encryption Tool
          </span>
          <h1 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none mb-4">
            CAESAR CIPHER
          </h1>
        </div>

        <div class="bg-paper-white rounded-cards border border-silver/50 p-8 sm:p-10 shadow-subtle">
          <div class="space-y-6">
            <div>
              <label for="inputText" class="block mb-2 font-inter font-medium text-body-sm text-obsidian select-none">
                Input Text
              </label>
              <textarea
                id="inputText"
                rows="4"
                class="w-full rounded-cards border border-silver/50 bg-concrete px-4 py-3 font-inter-display font-medium text-body text-obsidian focus:outline-none focus:border-silver transition-colors"
                placeholder="Type text to encrypt or decrypt..."
              ></textarea>
            </div>

            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
              <div class="w-full sm:w-auto">
                <label for="shiftValue" class="block mb-2 font-inter font-medium text-body-sm text-obsidian select-none">
                  Shift Value
                </label>
                <input
                  id="shiftValue"
                  type="number"
                  value="3"
                  class="w-full sm:w-48 rounded-cards border border-silver/50 bg-concrete px-4 py-2 font-inter-display font-medium text-body text-obsidian focus:outline-none focus:border-silver transition-colors"
                />
              </div>

              <div class="flex flex-wrap gap-3 self-end w-full sm:w-auto justify-end">
                <button
                  id="encryptBtn"
                  class="px-5 py-2.5 rounded-buttons font-inter font-medium text-body-sm bg-solar-beam text-obsidian border border-solar-beam hover:bg-obsidian hover:text-paper-white hover:border-obsidian transition-colors cursor-pointer"
                >
                  Encrypt
                </button>
                <button
                  id="decryptBtn"
                  class="px-5 py-2.5 rounded-buttons font-inter font-medium text-body-sm bg-solar-beam text-obsidian border border-solar-beam hover:bg-obsidian hover:text-paper-white hover:border-obsidian transition-colors cursor-pointer"
                >
                  Decrypt
                </button>
                <button
                  id="swapBtn"
                  class="px-5 py-2.5 rounded-buttons font-inter font-medium text-body-sm bg-concrete text-obsidian border border-silver/50 hover:bg-solar-beam hover:border-solar-beam transition-colors cursor-pointer"
                >
                  Swap
                </button>
                <button
                  id="clearBtn"
                  class="px-5 py-2.5 rounded-buttons font-inter font-medium text-body-sm bg-concrete text-obsidian border border-silver/50 hover:bg-solar-beam hover:border-solar-beam transition-colors cursor-pointer"
                >
                  Clear
                </button>
              </div>
            </div>

            <div>
              <label for="outputText" class="block mb-2 font-inter font-medium text-body-sm text-obsidian select-none">
                Output
              </label>
              <textarea
                id="outputText"
                rows="4"
                readonly
                class="w-full rounded-cards border border-silver/50 bg-concrete px-4 py-3 font-inter-display font-medium text-body text-obsidian focus:outline-none cursor-default select-all"
                placeholder="Result will appear here..."
              ></textarea>
            </div>
          </div>
        </div>
      </section>
    </main>

    <Footer />
    <ThemeToggle />

    <script>
      // @ts-nocheck
      function caesarCipher(text, shift) {
        let result = "";
        for (let i = 0; i < text.length; i++) {
          let ch = text[i];
          const code = ch.charCodeAt(0);

          if (code >= 65 && code <= 90) {
            const normalized = (((code - 65 + shift) % 26) + 26) % 26;
            ch = String.fromCharCode(normalized + 65);
          } else if (code >= 97 && code <= 122) {
            const normalized = (((code - 97 + shift) % 26) + 26) % 26;
            ch = String.fromCharCode(normalized + 97);
          }

          result += ch;
        }

        return result;
      }

      const inputText = document.getElementById("inputText");
      const outputText = document.getElementById("outputText");
      const shiftValue = document.getElementById("shiftValue");
      const encryptBtn = document.getElementById("encryptBtn");
      const decryptBtn = document.getElementById("decryptBtn");
      const swapBtn = document.getElementById("swapBtn");
      const clearBtn = document.getElementById("clearBtn");

      function getShift() {
        const parsed = Number.parseInt(shiftValue.value, 10);
        return Number.isNaN(parsed) ? 0 : parsed;
      }

      encryptBtn?.addEventListener("click", () => {
        outputText.value = caesarCipher(inputText.value, getShift());
      });

      decryptBtn?.addEventListener("click", () => {
        outputText.value = caesarCipher(inputText.value, -getShift());
      });

      swapBtn?.addEventListener("click", () => {
        const temp = inputText.value;
        inputText.value = outputText.value;
        outputText.value = temp;
      });

      clearBtn?.addEventListener("click", () => {
        inputText.value = "";
        outputText.value = "";
        shiftValue.value = "3";
      });
    </script>
  </body>
</html>
