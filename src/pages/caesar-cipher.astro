---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { siteConfig } from "../config";
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="/favicon.svg" />
    <meta
      name="description"
      content="Simple Caesar Cipher tool to encrypt and decrypt text using a shift value."
    />
    <title>Caesar Cipher - {siteConfig.name}</title>
  </head>

  <body>
    <div
      class="relative isolate overflow-hidden bg-white min-h-screen"
      style={`--accent-color: ${siteConfig.accentColor}; background-color: white;`}
    >
      <div class="fixed inset-0 -z-10 hero-overlay" aria-hidden="true"></div>

      <svg
        aria-hidden="true"
        class="hero-bg-svg fixed inset-0 -z-10 size-full stroke-gray-200 dark:stroke-gray-800"
        style="mask-image: radial-gradient(100% 100% at top center, white, transparent);"
      >
        <defs>
          <pattern
            x="50%"
            y={-1}
            id="caesar-pattern"
            width={200}
            height={200}
            patternUnits="userSpaceOnUse"
          >
            <path d="M.5 200V.5H200" fill="none"></path>
          </pattern>
        </defs>
        <rect fill="url(#caesar-pattern)" width="100%" height="100%" stroke-width={0}></rect>
      </svg>

      <Header />

      <main id="hero" class="relative py-24 md:py-32 min-h-screen">
        <section class="mx-auto max-w-4xl px-6 lg:px-8">
          <div class="text-center mb-10">
            <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 dark:text-white">
              Caesar Cipher Tool
            </h1>
            <p class="mt-4 text-gray-600 dark:text-gray-300 text-lg">
              Encrypt or decrypt text with a simple shift value.
            </p>
          </div>

          <div class="bg-white dark:bg-gray-900/60 backdrop-blur-sm rounded-2xl border border-gray-200 dark:border-gray-800 p-6 sm:p-8 shadow-sm">
            <div class="space-y-5">
              <div>
                <label for="inputText" class="block mb-2 text-sm font-medium text-gray-700 dark:text-gray-200">
                  Input Text
                </label>
                <textarea
                  id="inputText"
                  rows="5"
                  class="w-full rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-4 py-3 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)]"
                  placeholder="Type text to encrypt or decrypt..."
                ></textarea>
              </div>

              <div>
                <label for="shiftValue" class="block mb-2 text-sm font-medium text-gray-700 dark:text-gray-200">
                  Shift Value
                </label>
                <input
                  id="shiftValue"
                  type="number"
                  value="3"
                  class="w-full sm:w-56 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-900 px-4 py-3 text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-[var(--accent-color)]"
                />
              </div>

              <div class="flex flex-wrap gap-3">
                <button
                  id="encryptBtn"
                  class="px-5 py-2.5 rounded-xl font-semibold text-white transition-all hover:opacity-90"
                  style={`background-color: ${siteConfig.accentColor};`}
                >
                  Encrypt
                </button>
                <button
                  id="decryptBtn"
                  class="px-5 py-2.5 rounded-xl font-semibold text-white transition-all hover:opacity-90"
                  style={`background-color: ${siteConfig.accentColor};`}
                >
                  Decrypt
                </button>
                <button
                  id="swapBtn"
                  class="px-5 py-2.5 rounded-xl font-semibold bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-gray-100 hover:bg-gray-200 dark:hover:bg-gray-700 transition-all"
                >
                  Swap
                </button>
                <button
                  id="clearBtn"
                  class="px-5 py-2.5 rounded-xl font-semibold bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-gray-100 hover:bg-gray-200 dark:hover:bg-gray-700 transition-all"
                >
                  Clear
                </button>
              </div>

              <div>
                <label for="outputText" class="block mb-2 text-sm font-medium text-gray-700 dark:text-gray-200">
                  Output
                </label>
                <textarea
                  id="outputText"
                  rows="5"
                  readonly
                  class="w-full rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 px-4 py-3 text-gray-900 dark:text-gray-100 focus:outline-none"
                  placeholder="Result will appear here..."
                ></textarea>
              </div>
            </div>
          </div>
        </section>
      </main>

      <Footer />
      <ThemeToggle />
    </div>

    <script>
      function caesarCipher(text, shift) {
        let result = "";
        for (let i = 0; i < text.length; i++) {
          let ch = text[i];
          const code = ch.charCodeAt(0);

          if (code >= 65 && code <= 90) {
            const normalized = (((code - 65 + shift) % 26) + 26) % 26;
            ch = String.fromCharCode(normalized + 65);
          } else if (code >= 97 && code <= 122) {
            const normalized = (((code - 97 + shift) % 26) + 26) % 26;
            ch = String.fromCharCode(normalized + 97);
          }

          result += ch;
        }

        return result;
      }

      const inputText = document.getElementById("inputText");
      const outputText = document.getElementById("outputText");
      const shiftValue = document.getElementById("shiftValue");
      const encryptBtn = document.getElementById("encryptBtn");
      const decryptBtn = document.getElementById("decryptBtn");
      const swapBtn = document.getElementById("swapBtn");
      const clearBtn = document.getElementById("clearBtn");

      function getShift() {
        const parsed = Number.parseInt(shiftValue.value, 10);
        return Number.isNaN(parsed) ? 0 : parsed;
      }

      encryptBtn?.addEventListener("click", () => {
        outputText.value = caesarCipher(inputText.value, getShift());
      });

      decryptBtn?.addEventListener("click", () => {
        outputText.value = caesarCipher(inputText.value, -getShift());
      });

      swapBtn?.addEventListener("click", () => {
        const temp = inputText.value;
        inputText.value = outputText.value;
        outputText.value = temp;
      });

      clearBtn?.addEventListener("click", () => {
        inputText.value = "";
        outputText.value = "";
        shiftValue.value = "3";
      });
    </script>
  </body>
</html>
