---
import { siteConfig } from "../config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

const features = [
  {
    icon: "🤖",
    title: "AI-Powered Intelligence",
    description: "Advanced algorithms automatically resolve scheduling conflicts and optimize timetables for maximum efficiency."
  },
  {
    icon: "📚",
    title: "NEP 2020 Compliant",
    description: "Built with National Education Policy guidelines in mind, ensuring your schedules meet modern educational standards."
  },
  {
    icon: "⚡",
    title: "Lightning Fast",
    description: "Generate complex timetables in seconds, not hours. Save valuable time for what really matters - education."
  },
  {
    icon: "🎯",
    title: "Conflict-Free Scheduling",
    description: "Intelligent constraint handling ensures zero conflicts between teachers, rooms, and student groups."
  },
  {
    icon: "📊",
    title: "Visual Analytics",
    description: "Beautiful, interactive dashboards to visualize schedules, track utilization, and identify optimization opportunities."
  },
  {
    icon: "🔄",
    title: "Easy Modifications",
    description: "Make changes on the fly with automatic conflict detection and instant schedule adjustments."
  }
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="description" content="Catalyst - AI-powered timetable generator for schools and colleges. Create NEP-compliant, conflict-free schedules in seconds." />
    <title>Catalyst - AI-Powered Timetable Generator</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Inter:wght@500&family=Reddit+Sans+Condensed:wght@900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-concrete text-obsidian">
    <Header />

    <!-- Hero Section -->
    <main class="relative py-32 flex items-center justify-center min-h-[70vh]">
      <!-- Diagonal wash of light -->
      <div
        class="absolute top-0 right-0 w-[60%] h-full -z-10 pointer-events-none"
        style="background: radial-gradient(circle at 100% 0%, var(--color-solar-beam) 0%, transparent 60%); opacity: 0.25; filter: blur(40px);"
      ></div>

      <div class="mx-auto max-w-4xl px-6 lg:px-8 text-center flex flex-col items-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-paper-white border border-silver/50 rounded-buttons mb-8 select-none shadow-subtle">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-solar-beam opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-solar-beam"></span>
          </span>
          <span class="font-inter font-medium text-caption text-graphite">Launched December 25, 2025</span>
        </div>
        
        <h1 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none mb-6">
          CATALYST
        </h1>
        
        <p class="font-inter-display font-medium text-body text-graphite mb-10 leading-relaxed max-w-2xl">
          Revolutionize academic scheduling with intelligent, conflict-free timetable generation. Save hours of manual work and eliminate scheduling headaches.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a 
            href="https://cataylst.vercel.app/" 
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-3 bg-solar-beam text-obsidian rounded-buttons font-inter font-medium text-body-sm border border-solar-beam hover:bg-obsidian hover:text-paper-white hover:border-obsidian transition-colors duration-200 cursor-pointer"
          >
            View Live Demo
          </a>
          <a 
            href="#features" 
            class="px-8 py-3 bg-concrete text-obsidian rounded-buttons font-inter font-medium text-body-sm border border-silver/50 hover:bg-solar-beam hover:border-solar-beam transition-colors duration-200 cursor-pointer"
          >
            Explore Features
          </a>
        </div>
      </div>
    </main>

    <!-- Features Section -->
    <section id="features" class="py-24 px-8 sm:px-12 md:px-24 border-t border-silver/30 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-[1200px] flex flex-col items-center">
        <!-- Section Title Block -->
        <div class="flex flex-col items-center mb-16">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Perfect Scheduling
          </span>
          <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
            FEATURES
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full text-left">
          {features.map((feature) => (
            <div class="group bg-paper-white p-8 sm:p-10 rounded-cards border border-silver/50 shadow-subtle hover:border-silver transition-all duration-300">
              <div class="text-5xl mb-4 select-none">{feature.icon}</div>
              <h3 class="font-inter font-medium text-subheading text-obsidian mb-3">
                {feature.title}
              </h3>
              <p class="font-inter-display font-medium text-body text-graphite leading-relaxed">
                {feature.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech Stack Section -->
    <section class="py-24 px-8 sm:px-12 md:px-24 border-t border-silver/30 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-[1200px] flex flex-col items-center">
        <!-- Section Title Block -->
        <div class="flex flex-col items-center mb-16">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Technologies Utilized
          </span>
          <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
            TECH STACK
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 w-full">
          {["Next.js", "TypeScript", "JavaScript", "SQL", "AI", "TailwindCSS"].map((tech) => (
            <div class="bg-paper-white p-6 rounded-cards border border-silver/50 text-center shadow-subtle hover:border-silver transition-colors duration-300">
              <p class="font-inter font-medium text-body-sm text-obsidian select-none">{tech}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-24 px-8 sm:px-12 md:px-24 border-t border-silver/30 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-4xl flex flex-col items-center">
        <div class="bg-paper-white p-12 rounded-cards border border-silver/50 w-full shadow-subtle">
          <h2 class="font-reddit-sans-condensed font-black text-heading-lg text-obsidian uppercase select-none mb-6">
            Ready to Transform Your Scheduling?
          </h2>
          <p class="font-inter-display font-medium text-body text-graphite mb-10 leading-relaxed max-w-xl mx-auto">
            Join the future of academic timetable management with Catalyst.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href={siteConfig.social.email ? `mailto:${siteConfig.social.email}?subject=Catalyst Inquiry` : "#"}
              class="px-8 py-3 bg-solar-beam text-obsidian border border-solar-beam rounded-buttons font-inter font-medium text-body-sm hover:bg-obsidian hover:text-paper-white hover:border-obsidian transition-colors duration-200 cursor-pointer"
            >
              Get in Touch
            </a>
            <a 
              href="/" 
              class="px-8 py-3 bg-concrete text-obsidian border border-silver/50 rounded-buttons font-inter font-medium text-body-sm hover:bg-solar-beam hover:border-solar-beam transition-colors duration-200 cursor-pointer"
            >
              Back to Portfolio
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
    <ThemeToggle />
  </body>
</html>
