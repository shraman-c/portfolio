---
import { siteConfig } from "../config";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

const features = [
  {
    icon: "👁️",
    title: "Real-time Monitoring",
    description: "Automatically watches folders and organizes files as they're created, with zero latency."
  },
  {
    icon: "🤖",
    title: "Smart Categorization",
    description: "Intelligently sorts files by extension into configurable categories with custom rules."
  },
  {
    icon: "⚙️",
    title: "Dual-Mode Operation",
    description: "Switch between intuitive GUI and powerful CLI with full feature parity."
  },
  {
    icon: "📁",
    title: "Multi-folder Support",
    description: "Watch multiple directories simultaneously with independent settings for each."
  },
  {
    icon: "🔒",
    title: "Safe & Non-recursive",
    description: "Only organizes top-level files - subfolders are never touched or modified."
  },
  {
    icon: "🚀",
    title: "Zero Configuration",
    description: "Works perfectly out of the box with sensible defaults - no setup required."
  }
];

const techStack = ["Python 3.9+", "Watchdog", "Tkinter", "PyInstaller", "Cross-platform"];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Watcher - Auto-organize your downloads and folders by file type in real-time. Works on Windows, macOS, and Linux." />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" href="/favicon.svg" />
    <link rel="canonical" href="https://shramanc.pages.dev/watcher" />
    <title>Watcher - Auto-Organize Files by Type</title>

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://shramanc.pages.dev/watcher" />
    <meta property="og:title" content="Watcher - Auto-Organize Files by Type" />
    <meta property="og:description" content="Watcher - Auto-organize your downloads and folders by file type in real-time. Works on Windows, macOS, and Linux." />
    <meta property="og:image" content="https://shramanc.pages.dev/images/avt.png" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://shramanc.pages.dev/watcher" />
    <meta property="twitter:title" content="Watcher - Auto-Organize Files by Type" />
    <meta property="twitter:description" content="Watcher - Auto-organize your downloads and folders by file type in real-time. Works on Windows, macOS, and Linux." />
    <meta property="twitter:image" content="https://shramanc.pages.dev/images/avt.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&family=Inter:wght@500&family=Reddit+Sans+Condensed:wght@900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-concrete text-obsidian">
    <Header />

    <!-- Hero Section -->
    <main class="relative py-32 flex items-center justify-center min-h-[70vh]">
      <!-- Diagonal wash of light -->
      <div
        class="absolute top-0 right-0 w-[60%] h-full -z-10 pointer-events-none"
        style="background: radial-gradient(circle at 100% 0%, var(--color-solar-beam) 0%, transparent 60%); opacity: 0.25; filter: blur(40px);"
      ></div>

      <div class="mx-auto max-w-4xl px-6 lg:px-8 text-center flex flex-col items-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 bg-paper-white border border-silver/50 rounded-buttons mb-8 select-none shadow-subtle">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-solar-beam opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-solar-beam"></span>
          </span>
          <span class="font-inter font-medium text-caption text-graphite">v1.0.0.1a Now Available</span>
        </div>
        
        <h1 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none mb-6">
          WATCHER
        </h1>
        
        <p class="font-inter-display font-medium text-body text-graphite mb-10 leading-relaxed max-w-2xl">
          Stop managing messy download folders. Automatically organize files by type in real-time with intelligent categorization.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a 
            href="https://github.com/shraman-c/watcher/releases" 
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-3 bg-solar-beam text-obsidian border border-solar-beam rounded-buttons font-inter font-medium text-body-sm hover:bg-obsidian hover:text-paper-white hover:border-obsidian transition-colors duration-200 cursor-pointer flex items-center gap-2"
          >
            <span>Download Now</span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
          </a>
          <a 
            href="#features" 
            class="px-8 py-3 bg-concrete text-obsidian border border-silver/50 rounded-buttons font-inter font-medium text-body-sm hover:bg-solar-beam hover:border-solar-beam transition-colors duration-200 cursor-pointer"
          >
            Learn More
          </a>
          <a 
            href="https://github.com/shraman-c/watcher" 
            target="_blank"
            rel="noopener noreferrer"
            class="px-8 py-3 bg-concrete text-obsidian border border-silver/50 rounded-buttons font-inter font-medium text-body-sm hover:bg-solar-beam hover:border-solar-beam transition-colors duration-200 cursor-pointer flex items-center gap-2"
          >
            <span>GitHub</span>
          </a>
        </div>
      </div>
    </main>

    <!-- Features Section -->
    <section id="features" class="py-24 px-8 sm:px-12 md:px-24 border-t border-silver/30 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-[1200px] flex flex-col items-center">
        <!-- Section Title Block -->
        <div class="flex flex-col items-center mb-16">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Auto-organize Folders
          </span>
          <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
            FEATURES
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 w-full text-left">
          {features.map((feature) => (
            <div class="group bg-paper-white p-8 sm:p-10 rounded-cards border border-silver/50 shadow-subtle hover:border-silver transition-all duration-300">
              <div class="text-5xl mb-4 select-none">{feature.icon}</div>
              <h3 class="font-inter font-medium text-subheading text-obsidian mb-3">
                {feature.title}
              </h3>
              <p class="font-inter-display font-medium text-body text-graphite leading-relaxed">
                {feature.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Built for Everyone Section -->
    <section class="py-24 px-8 sm:px-12 md:px-24 border-t border-silver/30 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-[1200px] flex flex-col items-center">
        <!-- Section Title Block -->
        <div class="flex flex-col items-center mb-16">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Accessible & Lightweight
          </span>
          <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
            VERSATILE
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full text-left">
          <div class="bg-paper-white p-8 sm:p-10 rounded-cards border border-silver/50 shadow-subtle hover:border-silver transition-colors duration-300">
            <div class="text-4xl mb-4 select-none">🖥️</div>
            <h3 class="font-inter font-medium text-subheading text-obsidian mb-3">Modern GUI</h3>
            <p class="font-inter-display font-medium text-body text-graphite leading-relaxed">
              Intuitive tkinter interface with drag-and-drop folder management, inline rules editor, and real-time status monitoring.
            </p>
          </div>

          <div class="bg-paper-white p-8 sm:p-10 rounded-cards border border-silver/50 shadow-subtle hover:border-silver transition-colors duration-300">
            <div class="text-4xl mb-4 select-none">⚡</div>
            <h3 class="font-inter font-medium text-subheading text-obsidian mb-3">Powerful CLI</h3>
            <p class="font-inter-display font-medium text-body text-graphite leading-relaxed">
              Full-featured command-line interface with custom rules, batch operations, and automation support for advanced users.
            </p>
          </div>

          <div class="bg-paper-white p-8 sm:p-10 rounded-cards border border-silver/50 shadow-subtle hover:border-silver transition-colors duration-300">
            <div class="text-4xl mb-4 select-none">🌍</div>
            <h3 class="font-inter font-medium text-subheading text-obsidian mb-3">Cross-Platform</h3>
            <p class="font-inter-display font-medium text-body text-graphite leading-relaxed">
              Runs seamlessly on Windows, macOS, and Linux. Single executable or Python script - your choice.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Tech Stack Section -->
    <section class="py-24 px-8 sm:px-12 md:px-24 border-t border-silver/30 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-[1200px] flex flex-col items-center">
        <!-- Section Title Block -->
        <div class="flex flex-col items-center mb-16">
          <span class="font-caveat text-graphite text-[28px] tracking-tight mb-2 select-none">
            Technologies Utilized
          </span>
          <h2 class="text-obsidian font-reddit-sans-condensed font-black text-display leading-none tracking-tighter uppercase select-none">
            TECH STACK
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 w-full">
          {techStack.map((tech) => (
            <div class="bg-paper-white p-6 rounded-cards border border-silver/50 text-center shadow-subtle hover:border-silver transition-colors duration-300">
              <p class="font-inter font-medium text-body-sm text-obsidian select-none">{tech}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Quick Start Section -->
    <section class="py-24 px-8 sm:px-12 md:px-24 border-t border-silver/30 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-4xl flex flex-col items-center">
        <div class="bg-paper-white p-12 rounded-cards border border-silver/50 w-full shadow-subtle text-left">
          <h2 class="font-reddit-sans-condensed font-black text-heading-lg text-obsidian uppercase select-none text-center mb-12">
            Get Started in 30 Seconds
          </h2>
          <div class="space-y-8 max-w-2xl mx-auto">
            <div class="flex gap-5">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-10 w-10 rounded-full bg-solar-beam text-obsidian font-bold select-none">1</div>
              </div>
              <div>
                <h3 class="font-inter font-medium text-body text-obsidian mb-1">Download</h3>
                <p class="font-inter-display font-medium text-body-sm text-graphite">Grab the latest release from GitHub - no installation needed for Windows users.</p>
              </div>
            </div>
            <div class="flex gap-5">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-10 w-10 rounded-full bg-solar-beam text-obsidian font-bold select-none">2</div>
              </div>
              <div>
                <h3 class="font-inter font-medium text-body text-obsidian mb-1">Add Folders</h3>
                <p class="font-inter-display font-medium text-body-sm text-graphite">Select the folders you want Watcher to monitor (Downloads, Desktop, etc.).</p>
              </div>
            </div>
            <div class="flex gap-5">
              <div class="flex-shrink-0">
                <div class="flex items-center justify-center h-10 w-10 rounded-full bg-solar-beam text-obsidian font-bold select-none">3</div>
              </div>
              <div>
                <h3 class="font-inter font-medium text-body text-obsidian mb-1">Start Watching</h3>
                <p class="font-inter-display font-medium text-body-sm text-graphite">Click Start and watch as your files are organized automatically in real-time.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-24 px-8 sm:px-12 md:px-24 border-t border-silver/30 bg-concrete flex flex-col items-center text-center">
      <div class="w-full max-w-4xl flex flex-col items-center">
        <div class="bg-paper-white p-12 rounded-cards border border-silver/50 w-full shadow-subtle">
          <h2 class="font-reddit-sans-condensed font-black text-heading-lg text-obsidian uppercase select-none mb-6">
            Never Sort Files Manually Again
          </h2>
          <p class="font-inter-display font-medium text-body text-graphite mb-10 leading-relaxed max-w-xl mx-auto">
            Join developers and students who've already automated their file organization.
          </p>
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a 
              href="https://github.com/shraman-c/watcher/releases" 
              target="_blank"
              rel="noopener noreferrer"
              class="px-8 py-3 bg-solar-beam text-obsidian border border-solar-beam rounded-buttons font-inter font-medium text-body-sm hover:bg-obsidian hover:text-paper-white hover:border-obsidian transition-colors duration-200 cursor-pointer flex items-center justify-center gap-2"
            >
              <span>Download Release</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
            <a 
              href="/" 
              class="px-8 py-3 bg-concrete text-obsidian border border-silver/50 rounded-buttons font-inter font-medium text-body-sm hover:bg-solar-beam hover:border-solar-beam transition-colors duration-200 cursor-pointer"
            >
              Back to Portfolio
            </a>
          </div>
        </div>
      </div>
    </section>

    <Footer />
    <ThemeToggle />
  </body>
</html>
